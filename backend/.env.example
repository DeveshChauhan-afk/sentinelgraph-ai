# ==============================================================================
# SentinelGraph AI - Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in the required values.
# DO NOT commit the real .env file to version control.
# ==============================================================================

# =========================
# Project Configuration
# =========================
# Overrides are optional; default values are defined in app/core/config.py
DEBUG=True

# =========================
# Security
# =========================
# Generate a secure random string: openssl rand -hex 32
SECRET_KEY=your-super-secret-random-string-here

# =========================
# Database (PostgreSQL)
# =========================
# Use "postgres" as DATABASE_HOST when running inside Docker Compose
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=sentinel_db
DATABASE_USER=sentinel_user
DATABASE_PASSWORD=your_postgres_password

# Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# =========================
# Neo4j Graph Database
# =========================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# =========================
# AI / LLM Configuration
# =========================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096